{
  "name": "whatsapp-scheduler",
  "version": "1.0.0",
  "description": "Personal WhatsApp scheduled message sender (whatsapp-web.js + Express + SQLite)",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:logs": "pm2 logs whatsapp-scheduler",
    "pm2:stop": "pm2 stop whatsapp-scheduler",
    "pm2:restart": "pm2 restart whatsapp-scheduler",
    "reset:cache": "node scripts/reset.js cache",
    "reset:auth": "node scripts/reset.js auth",
    "reset:all": "node scripts/reset.js all"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "better-sqlite3": "^11.3.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "fluent-ffmpeg": "^2.1.3",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "qrcode": "^1.5.4",
    "whatsapp-web.js": "^1.26.0",
    "winston": "^3.14.2",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  }
}
